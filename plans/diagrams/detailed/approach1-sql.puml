@startuml approach1-sql-detailed
title **Approach 1: InMemoryContainer — SQL Query Flow (Detailed)**

skinparam backgroundColor #FEFEFE
skinparam sequenceArrowThickness 2
skinparam sequenceParticipantBorderColor #333
skinparam sequenceLifeLineBorderColor #999

actor "Test Code" as Test
participant "InMemoryContainer\n(extends Container)" as IMC
participant "CosmosSqlParser" as Parser
participant "CosmosSqlQuery\n(AST record)" as AST
participant "InMemoryContainer\n.FilterItemsByQuery()" as Filter
participant "InMemoryContainer\n.EvaluateSqlExpression()" as Eval
participant "InMemoryFeedIterator<T>" as FeedIter
participant "InMemoryFeedResponse<T>\n(extends FeedResponse<T>)" as FeedResp

Test -> IMC ++ : GetItemQueryIterator<T>(queryText,\n  continuationToken, requestOptions)
IMC -> Filter ++ : FilterItemsByQuery(queryText,\n  parameters, requestOptions)
Filter -> Parser ++ : Parse(queryText)
Parser --> AST ** : CosmosSqlQuery\n(SelectFields, Where,\n OrderBy, GroupBy, …)
Parser --> Filter -- : return parsed query
Filter -> Filter : GetAllItemsForPartition(requestOptions)\n→ List<string> from in-memory store
Filter -> Filter : AugmentWithComputedProperties()
Filter -> Filter : ExpandFromSource()\n(FROM c IN c.field)
Filter -> Filter : ExpandAllJoins()\n(JOIN expansion)

group WHERE clause evaluation
  Filter -> Eval ++ : EvaluateWhereExpression\n(expr, JObject item)
  note right of Eval
    Recursively evaluates:
    • LiteralExpression
    • IdentifierExpression
    • PropertyAccessExpression
    • IndexAccessExpression (c.tags[0])
    • BinaryExpression (=, <, +, ||, AND, OR…)
    • UnaryExpression (NOT, Negate, BitwiseNot)
    • FunctionCallExpression (UPPER, CONTAINS,
      ST_DISTANCE, ARRAY_LENGTH, etc. — 40+ functions)
    • BetweenExpression (BETWEEN low AND high)
    • InExpression (IN (val, val, …))
    • LikeExpression (LIKE pattern [ESCAPE char])
    • TernaryExpression (condition ? ifTrue : ifFalse)
    • CoalesceExpression (left ?? right)
    • SubqueryExpression ((SELECT …))
    • ArrayLiteralExpression ([expr, expr, …])
    • ObjectLiteralExpression ({key: expr, key: expr})
  end note
  Eval --> Filter -- : bool (include/exclude)
end

Filter -> Filter : ApplyGroupBy() + aggregates\n(COUNT, SUM, AVG, MIN, MAX)
Filter -> Filter : ApplyOrderByFields()\n(multi-field, ASC/DESC)
Filter -> Filter : TOP / OFFSET+LIMIT
Filter -> Filter : ProjectFields()\n(SELECT projection — named fields,\n aliased expressions, nested objects)
Filter -> Filter : StripComputedProperties()\n(remove virtual props from SELECT *)
Filter -> Filter : DISTINCT\n(on projected shape)
Filter -> Filter : UnwrapValueSelect()\n(SELECT VALUE → extract scalar)
Filter --> IMC -- : List<string> (JSON documents)

IMC -> IMC : Deserialize each JSON →\nJsonConvert.DeserializeObject<T>()
IMC -> FeedIter ** : new InMemoryFeedIterator<T>\n(items, maxItemCount, initialOffset)
IMC --> Test -- : FeedIterator<T>

loop while FeedIter.HasMoreResults
  Test -> FeedIter ++ : ReadNextAsync()
  FeedIter -> FeedIter : EnsureItems()\n(lazily evaluate factory delegate if provided)
  FeedIter -> FeedIter : Paginate: Skip(offset).Take(maxItemCount)
  FeedIter -> FeedIter : Generate continuation token\n(offset-based, null if last page)
  FeedIter -> FeedResp ** : new InMemoryFeedResponse<T>\n(page of items, continuationToken,\n Headers: x-ms-request-charge,\n x-ms-activity-id)
  FeedIter --> Test -- : FeedResponse<T>
end

@enduml
